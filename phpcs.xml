<?xml version="1.0"?>
<ruleset name="MyProject">
    <description>PHP CodeSniffer configuration</description>

    <file>public/</file>

    <rule ref="PSR12">
        <exclude name="PSR1.Files.SideEffects"/>
        <exclude name="PSR12.Files.FileHeader.SpacingAfterBlock"/>
    </rule>

    <arg name="colors"/>
    <arg value="p"/>

    <ini name="memory_limit" value="256M"/>
</ruleset>